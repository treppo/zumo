{:tasks
 {dev {:doc "Run in development mode with REPL"
       :task (shell "clojure -M:dev")}

  outdated {:doc "Show outdated dependencies"
            :task (shell "clojure -Sdeps '{:deps {com.github.liquidz/antq {:mvn/version \"2.11.1276\"}}}' -M -m antq.core")}

  upgrade {:doc "Upgrade outdated dependencies"
           :task (shell "clojure -Sdeps '{:deps {com.github.liquidz/antq {:mvn/version \"2.11.1276\"}}}' -M -m antq.core --upgrade --force")}

  run {:doc "Run the application"
       :task (shell {:extra-env {"PROFILE" "local"}} "clojure -M:run")
       :override-builtin true}

  test {:doc "Run the tests"
        :task (shell {:extra-env {"PROFILE" "test"}} "clojure -X:test")
        :override-builtin true}

  clean {:doc "Clean build artifacts"
         :task (do
                 (fs/delete-tree "target")
                 (fs/delete-tree ".cpcache"))}

  uberjar {:doc "Build an uberjar (standalone JAR)"
           :task (shell "clojure -T:build uberjar")
           :override-builtin true}

  agent {:doc "Run coding agent"
         :task (shell "zerostack --provider openrouter --model deepseek/deepseek-v4-flash")}}}
